# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  –  copy to .env and fill in real values
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# docker-compose sets this automatically; override if using an external DB.
DATABASE_URL=postgresql://postgres.tuhjngcsrfzulakhuyce:NativeTalk2026!@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── JWT tokens ────────────────────────────────────────────────────────────────
# 32+ random bytes, base64 encoded.  Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_string_here

# Access token lifetime in minutes (default: 15).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 30).
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# JWT algorithm (default: HS256 – change with care).
JWT_ALGORITHM=HS256

# ── Google OAuth (React Native – ID token flow) ───────────────────────────────
# The Google OAuth2 *client ID* for your project.
# React Native app calls GoogleSignin.signIn() and sends the idToken to POST /api/v1/auth/google.
# The backend verifies the ID token signature using this client ID only.
# You do NOT need a client secret for this flow.
#
# Found in Google Cloud Console → Credentials → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=325878187070-dnnuldrknhhjffnr01jqb99s8d0bof2l.apps.googleusercontent.com

# ── Daily.co video calls ──────────────────────────────────────────────────────
# API key from https://dashboard.daily.co/developers
# Leave blank to run without video (endpoints will return HTTP 503 with instructions).
DAILY_API_KEY=

# Domain is auto-derived from the API key; override if needed.
DAILY_DOMAIN=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# React Native (Expo Go / bare): use the local dev machine IP + port, e.g.:
#   CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:8000
# Production: set to your actual domain(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://192.168.1.1:8000

# ── App settings ─────────────────────────────────────────────────────────────
# Used in logs and API health response.
APP_ENV=development   # development | staging | production

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
